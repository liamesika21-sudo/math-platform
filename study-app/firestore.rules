rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ─────────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAuthed() {
      return request.auth != null;
    }

    // ── Theory Feedback ────────────────────────────────────────────────────────
    // Doc ID: {courseId}__{itemId}__{userId}
    match /theoryFeedback/{docId} {
      // Admin reads everything (for insights dashboard)
      allow read: if isAdmin();

      // Student reads own docs
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;

      // Student creates a new doc — must own it
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['got_it', 'needs_review', 'lost'];

      // Student updates/deletes own doc
      allow update: if isAuthed()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['got_it', 'needs_review', 'lost'];

      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // ── Students ───────────────────────────────────────────────────────────────
    // Written only by Admin SDK (server-side import route) — students can read own doc
    match /students/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow read, write: if isAdmin();
      // Server-side Admin SDK bypasses rules — no client write needed
    }

    // ── Courses & uploaded content ─────────────────────────────────────────────
    // Written only by Admin SDK (upload route). Students can read.
    match /courses/{courseId} {
      allow read: if isAuthed();
      allow write: if isAdmin();

      match /content/{docId} {
        allow read: if isAuthed();
        allow write: if isAdmin();
      }
    }

  }
}
